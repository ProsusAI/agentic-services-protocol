{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./services/shared/image.json",
  "title": "Image",
  "description": "Image reference with URL and optional dimensions.",
  "type": "object",
  "required": [
    "url"
  ],
  "properties": {
    "url": {
      "type": "string",
      "format": "uri",
      "description": "URL of the image."
    },
    "alt_text": {
      "type": "string",
      "description": "Accessible alt text for the image."
    },
    "width": {
      "type": "integer",
      "description": "Image width in pixels.",
      "minimum": 1
    },
    "height": {
      "type": "integer",
      "description": "Image height in pixels.",
      "minimum": 1
    },
    "type": {
      "type": "string",
      "description": "Purpose of this image. Helps clients pick the right asset for context (e.g. thumbnail for search results, banner for detail page).",
      "enum": ["thumbnail", "banner", "logo", "hero"]
    }
  }
}
