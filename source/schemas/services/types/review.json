{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./services/types/review.json",
  "title": "Review",
  "description": "A post-service review submitted by a customer.",
  "type": "object",
  "required": ["id", "order_id", "provider_id", "rating", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique review identifier."
    },
    "order_id": {
      "type": "string",
      "description": "The order this review is for."
    },
    "provider_id": {
      "type": "string",
      "description": "The provider being reviewed."
    },
    "rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5,
      "description": "Overall rating out of 5."
    },
    "comment": {
      "type": "string",
      "description": "Optional free-text review.",
      "maxLength": 2000
    },
    "scores": {
      "type": "object",
      "description": "Optional category scores, e.g. {\"food\": 5, \"delivery\": 3} or {\"cleanliness\": 4, \"location\": 5}.",
      "additionalProperties": {
        "type": "number",
        "minimum": 1,
        "maximum": 5
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the review was submitted."
    }
  }
}
